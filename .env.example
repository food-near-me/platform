# Core app
NEXT_PUBLIC_APP_URL=https://foodnear.me
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Ed25519 signing for the `verified` Menu Protocol tier.
# Generate with: cd apps/web && npm run gen:signing-key
# Newlines in PEM blocks may be escaped as \n on Vercel / .env.
FNM_VERIFIED_SIGNING_KEY=
FNM_VERIFIED_SIGNING_PUBLIC_KEY=

# Local migrations only (Supabase Dashboard → Settings → Database → password)
SUPABASE_DB_PASSWORD=

# Distributed rate limiter (Upstash Redis REST).
# When both are set, all rate-limit counters are stored in Redis so limits
# survive serverless cold starts and apply across regions/instances.
# When unset, the limiter falls back to a per-process in-memory store
# (fine for local dev; NOT suitable for multi-instance production).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Optional namespace + timeout (defaults: "fnm:rl" / 1500ms)
# UPSTASH_RATE_LIMIT_PREFIX=fnm:rl
# UPSTASH_RATE_LIMIT_TIMEOUT_MS=1500

RESEND_API_KEY=
LEADS_NOTIFICATION_TO=
LEADS_FROM_EMAIL=
LEADS_ALLOWED_ORIGINS=

# Cron jobs.
# Vercel Cron sends `Authorization: Bearer <CRON_SECRET>` to scheduled
# routes (see apps/web/vercel.json). The /api/cron/* routes fail closed
# when this is missing, so configure it in Production + Preview env.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# MCP operations.
# Optional comma-separated allowlist for the public MCP tool catalogue.
# Leave unset or "*" to expose all tools. Useful for temporary degradation
# during a partial tool outage without changing code.
# FNM_MCP_ENABLED_TOOLS=search_restaurants,get_menu

# x402 Phase A (guard + 402 responses; default off — no behavior change in production)
FNM_X402_ENABLED=0
FNM_X402_FREE_QUOTA_PER_DAY=100
FNM_X402_QUOTA_WINDOW_MS=86400000

# x402 Phase B (settlement) — leave unset until the top-up route is shipped.
# When set, the 402 body advertises it as the agent's top-up endpoint.
# FNM_X402_TOPUP_ENDPOINT=/api/v1/x402/top-up
FNM_X402_NETWORK=eip155:8453
FNM_X402_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
FNM_X402_MIN_TOPUP_USD=5
FNM_X402_MIN_BALANCE_USD=0.10

# Payments (Phase B+ settlement)
X402_RECIPIENT_WALLET=
USDC_CONTRACT_ADDRESS=
BASE_CHAIN_ID=8453

# Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Doma / Web3 (optional)
DOMA_API_KEY=
THIRDWEB_SECRET_KEY=
